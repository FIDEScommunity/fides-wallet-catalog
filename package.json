{
  "name": "fides-wallet-catalog",
  "version": "1.0.0",
  "description": "FIDES Community Wallet Catalog - Decentralized wallet registration and display",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "crawl": "tsx src/crawler/index.ts",
    "backfill:first-seen": "tsx src/crawler/backfill-first-seen.ts",
    "serve": "tsx src/server/index.ts",
    "typecheck:api": "tsc -p tsconfig.api.json",
    "validate": "ajv validate --spec=draft2020 -c ajv-formats -s schemas/wallet-catalog.schema.json -d 'community-catalogs/**/wallet-catalog.json' --strict=false",
    "check-links": "tsx scripts/check-links.ts"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@vercel/node": "^3.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "ajv-cli": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}

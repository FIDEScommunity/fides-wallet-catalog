{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fides.community/schemas/wallet-catalog/v2",
  "title": "FIDES Wallet Catalog Descriptor (v2)",
  "description": "Schema for describing digital wallets for the FIDES Community catalog. Organization profile (name, DID, website, logo, country, contact) is defined in the FIDES organization catalog; this file references it via orgId (same pattern as RP, issuer, and credential catalogs).",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "orgId", "wallets"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://fides.community/schemas/wallet-catalog/v2",
      "description": "Schema identifier - must be this exact value"
    },
    "orgId": {
      "type": "string",
      "pattern": "^org:[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Organization catalog id (e.g. org:animo). Must exist in https://github.com/FIDEScommunity/fides-organization-catalog — canonical name, DID, website, logo, country, and contact are resolved at crawl time from there."
    },
    "wallets": {
      "type": "array",
      "description": "List of wallets offered by this provider",
      "items": {
        "$ref": "#/definitions/Wallet"
      },
      "minItems": 1
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of last update (ISO 8601)"
    }
  },
  "definitions": {
    "RecognitionItem": {
      "type": "object",
      "description": "A titled recognition entry with optional link",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Display title"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Optional link to case study, certificate, or award page"
        }
      }
    },
    "WalletMedia": {
      "type": "object",
      "description": "Promotional media (Pro tier in public export)",
      "additionalProperties": false,
      "properties": {
        "videos": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "string",
            "format": "uri"
          },
          "description": "Demo or promotional video URLs"
        },
        "images": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "string",
            "format": "uri"
          },
          "description": "Screenshot or product image URLs"
        }
      },
      "anyOf": [
        {
          "required": ["videos"],
          "properties": {
            "videos": {
              "minItems": 1
            }
          }
        },
        {
          "required": ["images"],
          "properties": {
            "images": {
              "minItems": 1
            }
          }
        }
      ]
    },
    "WalletRecognitions": {
      "type": "object",
      "description": "Customer stories, certifications, and awards (Pro tier in public export)",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "customerStories": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "$ref": "#/definitions/RecognitionItem"
          }
        },
        "certifications": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "$ref": "#/definitions/RecognitionItem"
          }
        },
        "awardsAndRecognitions": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "$ref": "#/definitions/RecognitionItem"
          }
        }
      }
    },
    "Wallet": {
      "type": "object",
      "description": "A digital identity wallet",
      "required": ["id", "name", "type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the wallet within this catalog (lowercase alphanumeric with hyphens)",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "description": "Display name of the wallet"
        },
        "description": {
          "type": "string",
          "description": "Short description of the wallet and its purpose"
        },
        "logo": {
          "type": "string",
          "format": "uri",
          "description": "URL to the wallet's logo image"
        },
        "website": {
          "type": "string",
          "format": "uri",
          "description": "Landing page or website for the wallet"
        },
        "type": {
          "type": "string",
          "enum": ["personal", "organizational"],
          "description": "Wallet type"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["iOS", "Android", "Web", "Windows", "macOS", "Linux", "CLI"]
          }
        },
        "openSource": {
          "type": "boolean"
        },
        "license": {
          "type": "string",
          "enum": [
            "MIT",
            "Apache-2.0",
            "GPL-3.0-or-later",
            "AGPL-3.0-or-later",
            "LGPL-3.0-or-later",
            "EUPL-1.2",
            "MPL-2.0",
            "BSD-3-Clause",
            "ISC",
            "proprietary",
            "other"
          ],
          "description": "Software license when openSource is true; use proprietary for closed-source wallets"
        },
        "licenseOther": {
          "type": "string",
          "maxLength": 50,
          "description": "Required when license is other; free-text license name"
        },
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "deploymentModel": {
          "type": "string",
          "enum": ["saas", "on_premises", "hybrid"],
          "description": "How the wallet product is deployed for customers"
        },
        "slaAvailable": {
          "type": "boolean",
          "description": "Whether a service level agreement is available"
        },
        "pricing": {
          "type": "string",
          "maxLength": 1000,
          "description": "Pricing summary (Pro tier in public export)"
        },
        "media": {
          "$ref": "#/definitions/WalletMedia"
        },
        "recognitions": {
          "$ref": "#/definitions/WalletRecognitions"
        },
        "vcFormat": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "sd_jwt_vc",
              "mdoc",
              "jwt_vc",
              "vcdm_1_1",
              "vcdm_2_0",
              "anoncreds",
              "idemix",
              "apple_wallet_pass",
              "google_wallet_pass",
              "acdc"
            ]
          }
        },
        "issuanceProtocols": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "OpenID4VCI",
              "DIDComm Issue Credential v1",
              "DIDComm Issue Credential v2",
              "ISO 18013-5 (Device Retrieval)"
            ]
          }
        },
        "presentationProtocols": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "OpenID4VP",
              "DIDComm Present Proof v1",
              "DIDComm Present Proof v2",
              "ISO 18013-5",
              "SIOPv2"
            ]
          }
        },
        "supportedIdentifiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "did:web",
              "did:key",
              "did:jwk",
              "did:peer",
              "did:ebsi",
              "did:ion",
              "did:cheqd",
              "did:webvh",
              "did:indy",
              "did:ethr",
              "did:polygon",
              "did:dock",
              "did:eth",
              "did:gatc",
              "did:isbe",
              "did:kscirc",
              "x509",
              "X.509",
              "X509",
              "jwk"
            ]
          }
        },
        "keyStorage": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Software",
              "Secure Enclave (iOS)",
              "StrongBox (Android)",
              "TEE",
              "HSM",
              "Cloud KMS",
              "Smart Card",
              "FIDO2/WebAuthn"
            ]
          }
        },
        "signingAlgorithms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ES256",
              "ES384",
              "ES512",
              "ES256K",
              "EdDSA",
              "RS256",
              "PS256",
              "BBS+",
              "ML-DSA (FIPS 204)"
            ]
          }
        },
        "credentialStatusMethods": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "StatusList2021",
              "RevocationList2020",
              "OCSP",
              "CRL",
              "IETF Token Status List",
              "Token Status List",
              "W3C Verifiable Credentials Status List v2021",
              "Bitstring Status List",
              "BitstringStatusList v1.0"
            ]
          }
        },
        "interoperabilityProfiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "DIIP v4",
              "DIIP v5",
              "EWC v3",
              "EUDI Wallet ARF",
              "HAIP v1"
            ]
          }
        },
        "standards": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "features": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "eidasTrustServices": {
          "type": "array",
          "description": "Qualified eIDAS trust services this wallet integrates with or relies on",
          "items": {
            "type": "string",
            "enum": [
              "Q_CERT_ESIG",
              "Q_CERT_ESEAL",
              "Q_TIMESTAMP",
              "Q_ERDS",
              "Q_WAC",
              "Q_EARCH",
              "Q_VC",
              "Q_PRES",
              "Q_PRES_ESEAL",
              "Q_PRES_ESIG",
              "Q_VAL_ESEAL",
              "Q_VAL_ESIG",
              "Q_REM_MANAGE_Q_SEAL_CD",
              "Q_REM_MANAGE_Q_SIG_CD",
              "QEAA"
            ]
          }
        },
        "documentation": {
          "type": "string",
          "format": "uri"
        },
        "additionalDocumentation": {
          "type": "array",
          "description": "Extra documentation links (Pro tier in public export)",
          "maxItems": 10,
          "items": {
            "$ref": "#/definitions/RecognitionItem"
          }
        },
        "appStoreLinks": {
          "type": "object",
          "properties": {
            "iOS": {
              "type": "string",
              "format": "uri"
            },
            "android": {
              "type": "string",
              "format": "uri"
            },
            "web": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "status": {
          "type": "string",
          "enum": ["development", "beta", "production", "deprecated"]
        },
        "releaseDate": {
          "type": "string",
          "format": "date"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["holder", "issuer", "verifier"]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "license": {
                "const": "other"
              }
            },
            "required": ["license"]
          },
          "then": {
            "required": ["licenseOther"],
            "properties": {
              "licenseOther": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "license": {
                "enum": [
                  "MIT",
                  "Apache-2.0",
                  "GPL-3.0-or-later",
                  "AGPL-3.0-or-later",
                  "LGPL-3.0-or-later",
                  "EUPL-1.2",
                  "MPL-2.0",
                  "BSD-3-Clause",
                  "ISC",
                  "proprietary"
                ]
              }
            },
            "required": ["license"]
          },
          "then": {
            "not": {
              "required": ["licenseOther"]
            }
          }
        }
      ]
    }
  }
}

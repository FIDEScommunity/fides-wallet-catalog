{
  "buildCommand": "cp data/aggregated.json api/lib/aggregated.deploy.json && echo 'API data staged'",
  "installCommand": "npm ci",
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/**/*.ts": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "api/lib/aggregated.deploy.json"
    }
  }
}
